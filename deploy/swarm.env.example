IMAGE_REGISTRY=ghcr.io/your-github-username
IMAGE_TAG=latest
DOMAIN=hiremeplz.example.com
MONITORING_DOMAIN=monitor.hiremeplz.example.com
LETSENCRYPT_EMAIL=you@example.com
OPENAI_MODEL=gpt-4o-mini
JOB_ALERT_MIN_SCORE=0.75
GRAFANA_ADMIN_USER=admin
ALERT_EMAIL_SMARTHOST=smtp.sendgrid.net:587
ALERT_EMAIL_FROM=alerts@hiremeplz.example.com
ALERT_EMAIL_TO=you@example.com
ALERT_EMAIL_AUTH_USERNAME=apikey
ALERT_SLACK_CHANNEL=#hiremeplz-alerts
