{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "请求速率 (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(hiremeplz_http_requests_total[5m])) by (status_code)",
          "legendFormat": "{{status_code}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 10 },
          "unit": "reqps"
        },
        "overrides": []
      }
    },
    {
      "title": "请求延迟分位数",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(hiremeplz_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.90, sum(rate(hiremeplz_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p90",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(hiremeplz_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 5 },
          "unit": "s"
        },
        "overrides": []
      }
    },
    {
      "title": "5xx 错误率",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(hiremeplz_http_requests_total{status_code=~\"5..\"}[5m])) / sum(rate(hiremeplz_http_requests_total[5m])) * 100",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "title": "并发请求数",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 8 },
      "targets": [
        {
          "expr": "hiremeplz_http_requests_in_flight",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "title": "事件循环延迟",
      "type": "timeseries",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "hiremeplz_nodejs_eventloop_lag_seconds",
          "legendFormat": "lag",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 10 },
          "unit": "s"
        },
        "overrides": []
      }
    },
    {
      "title": "堆内存使用",
      "type": "timeseries",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 8 },
      "targets": [
        {
          "expr": "hiremeplz_nodejs_heap_size_used_bytes",
          "legendFormat": "used",
          "refId": "A"
        },
        {
          "expr": "hiremeplz_nodejs_heap_size_total_bytes",
          "legendFormat": "total",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 10 },
          "unit": "bytes"
        },
        "overrides": []
      }
    },
    {
      "title": "按路由 Top 10 请求速率",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "topk(10, sum(rate(hiremeplz_http_requests_total[5m])) by (route, method))",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "title": "按路由 P95 延迟",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "topk(10, histogram_quantile(0.95, sum(rate(hiremeplz_http_request_duration_seconds_bucket[5m])) by (le, route)))",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "title": "队列状态",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "hiremeplz_queue_waiting",
          "legendFormat": "{{ queue }} - waiting",
          "refId": "A"
        },
        {
          "expr": "hiremeplz_queue_active",
          "legendFormat": "{{ queue }} - active",
          "refId": "B"
        },
        {
          "expr": "hiremeplz_queue_failed",
          "legendFormat": "{{ queue }} - failed",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        },
        "overrides": []
      }
    },
    {
      "title": "进程内存 (RSS)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "targets": [
        {
          "expr": "process_resident_memory_bytes{job=\"hiremeplz-backend\"}",
          "legendFormat": "RSS",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 10 },
          "unit": "bytes"
        },
        "overrides": []
      }
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["hiremeplz"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "HireMePlz - 应用概览",
  "uid": "hiremeplz-overview"
}
